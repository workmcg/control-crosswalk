{
  "meta": {
    "title": "ISO 27001:2022 <-> NIST CSF 2.0 <-> NIS2 <-> DORA <-> SOC 2 control crosswalk",
    "version": "0.4.0",
    "description": "A complete crosswalk linking all 93 ISO/IEC 27001:2022 Annex A controls to NIST Cybersecurity Framework 2.0 subcategories, the cybersecurity risk-management measures in Article 21 of the NIS2 Directive (EU 2022/2555), the ICT risk management articles of DORA (EU 2022/2554), and the AICPA SOC 2 Trust Services Criteria (2017, as revised). Interpretive by nature -- see 'Scope and honesty about mappings' in the README before using for audit evidence.",
    "frameworks": {
      "iso27001": "ISO/IEC 27001:2022 Annex A (93/93 controls mapped, 4 themes)",
      "nist_csf": "NIST Cybersecurity Framework 2.0 (Functions: GV, ID, PR, DE, RS, RC)",
      "nis2": "Directive (EU) 2022/2555 (NIS2), Article 21(2) measures (a)-(j)",
      "dora": "Regulation (EU) 2022/2554 (DORA), ICT risk management / incident / testing / third-party articles",
      "soc2": "AICPA SOC 2 Trust Services Criteria: Security (Common Criteria CC1-CC9), Availability (A1), Confidentiality (C1), Processing Integrity (PI1), Privacy (P1-P8)"
    },
    "disclaimer": "Mappings are interpretive. Framework crosswalks are inherently approximate because controls differ in scope and intent. Always have mappings reviewed against the source standards before relying on them for audit or compliance evidence."
  },
  "nis2_article21_measures": {
    "21.2.a": "Policies on risk analysis and information system security",
    "21.2.b": "Incident handling",
    "21.2.c": "Business continuity, backup management, disaster recovery, crisis management",
    "21.2.d": "Supply chain security, including security-related aspects of relationships with suppliers",
    "21.2.e": "Security in network and information systems acquisition, development and maintenance, including vulnerability handling and disclosure",
    "21.2.f": "Policies and procedures to assess the effectiveness of cybersecurity risk-management measures",
    "21.2.g": "Basic cyber hygiene practices and cybersecurity training",
    "21.2.h": "Policies and procedures regarding the use of cryptography and, where appropriate, encryption",
    "21.2.i": "Human resources security, access control policies and asset management",
    "21.2.j": "Use of multi-factor authentication or continuous authentication, secured communications and secured emergency communication systems"
  },
  "dora_articles": {
    "Art.5": "Governance and organisation",
    "Art.6": "ICT risk management framework",
    "Art.7": "ICT systems, protocols and tools",
    "Art.8": "Identification (of ICT risk and ICT-supported business functions)",
    "Art.9": "Protection and prevention",
    "Art.10": "Detection",
    "Art.11": "Response and recovery",
    "Art.12": "Backup policies and procedures, restoration and recovery procedures and methods",
    "Art.13": "Learning and evolving",
    "Art.14": "Communication",
    "Art.17": "ICT-related incident management process",
    "Art.18": "Classification of ICT-related incidents and cyber threats",
    "Art.19": "Reporting of major ICT-related incidents and voluntary notification of significant cyber threats",
    "Art.24": "General requirements for digital operational resilience testing",
    "Art.26": "Advanced testing of ICT tools, systems and processes based on TLPT",
    "Art.28": "General principles for ICT third-party risk management",
    "Art.30": "Key contractual provisions"
  },
