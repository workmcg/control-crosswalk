  "soc2_trust_services_criteria": {
    "CC1": "Control Environment — integrity and ethical values, board oversight, organizational structure, authority and responsibility, and commitment to competence",
    "CC2": "Communication and Information — internal and external communication of security objectives, responsibilities and policies",
    "CC3": "Risk Assessment — identification and analysis of risks to objectives, including fraud risk and risk from change",
    "CC4": "Monitoring Activities — ongoing and separate evaluations to ascertain whether controls are present and functioning",
    "CC5": "Control Activities — selection and development of control activities that mitigate risk to acceptable levels",
    "CC6": "Logical and Physical Access Controls — restricting logical and physical access to systems, data and facilities to authorized users",
    "CC7": "System Operations — detecting, monitoring and responding to security events, incidents and vulnerabilities",
    "CC8": "Change Management — authorizing, designing, developing, testing, approving and implementing changes to infrastructure, software and procedures",
    "CC9": "Risk Mitigation — managing risk arising from potential business disruption and from vendor/business-partner relationships",
    "A1": "Availability — the system is available for operation and use as committed or agreed, including capacity planning and tested backup/recovery",
    "C1": "Confidentiality — information designated as confidential is protected as committed or agreed",
    "PI1": "Processing Integrity — system processing is complete, valid, accurate, timely and authorized",
    "P1": "Privacy: Notice — the entity provides notice about its privacy practices",
    "P2": "Privacy: Choice and Consent — the entity communicates choices and obtains consent for the collection, use and disclosure of personal information",
    "P3": "Privacy: Collection — personal information is collected consistently with the entity's objectives related to privacy",
    "P4": "Privacy: Use, Retention and Disposal — personal information is used, retained and disposed of consistently with the entity's commitments",
    "P5": "Privacy: Access — data subjects can access their personal information for review and, where appropriate, correction",
    "P6": "Privacy: Disclosure and Notification — personal information is disclosed to third parties, and breaches are communicated, consistently with commitments",
    "P7": "Privacy: Quality — personal information is accurate, complete and relevant to the purposes identified",
    "P8": "Privacy: Monitoring and Enforcement — the entity monitors compliance with its privacy commitments and addresses inquiries and complaints"
  }
}
